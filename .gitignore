# =====================================================================
# bsw-growth-agent · what NOT to push to GitHub
# =====================================================================

# ---- Private workshop materials (not for public) ----
docs/superpowers/
# script/ is intentionally PUBLISHED so attendees can reference the talk script
# alongside the slides — see script/speaker-notes.md

# ---- Local Claude Code config ----
.claude/
.cursor/
.aider*

# ---- Secrets · never commit ----
.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets/
credentials/

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# ---- Node / build artifacts (just in case) ----
node_modules/
dist/
build/
*.log
npm-debug.log*

# ---- Local n8n state (if anyone clones and runs n8n locally) ----
.n8n/
*.local.json

# ---- Backup files ----
*.bak
*.orig
