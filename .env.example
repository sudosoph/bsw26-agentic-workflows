# =====================================================================
# BSW Growth Agent · environment variables
# =====================================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored · NEVER commit your real keys.
#
# You don't strictly need .env for n8n.cloud (credentials live in
# n8n's encrypted credential store). This file is a checklist of
# what you need to gather.
# =====================================================================

# ---- Pick ONE LLM provider ----

# Option A · Anthropic Claude API (best quality, paid)
# Get key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Option B · OpenRouter (single key, many models, paid)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-REPLACE_ME

# Option C · Groq (FREE tier, fast Llama 3.3)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_ME

# Option D · Gemini (FREE tier, generous limits)
# Get key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=REPLACE_ME

# Option E · Ollama (local, no key needed)
# Install: https://ollama.com · run `ollama serve`
OLLAMA_BASE_URL=http://localhost:11434

# ---- Pick ONE web extraction provider ----

# Option A · Firecrawl (free tier 500 credits, paid Cloud at $83/mo)
# Get key from: https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-REPLACE_ME

# Option B · Jina Reader (FREE forever, no key, lower quality)
# No signup. Just GET https://r.jina.ai/<URL>
# (no env var needed)

# ---- Google Workspace (OAuth, no env var · auth happens in n8n UI) ----
# You'll connect Google Sheets + Drive + Gmail directly in n8n's
# credential editor when you import the workflow.
# Required scopes:
#   - Google Sheets: read/write
#   - Google Drive:  read
#   - Gmail:         compose (drafts) + send (digest only)

# ---- Workflow-specific config ----

# Your Google Sheet ID (from the URL between /d/ and /edit)
GOOGLE_SHEET_ID=REPLACE_ME

# Your voice.md file ID in Google Drive (between /d/ and /view)
VOICE_MD_FILE_ID=REPLACE_ME

# The email address that receives the daily digest (your own)
DIGEST_EMAIL=you@example.com
